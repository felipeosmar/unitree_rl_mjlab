      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rsl_rl_train_mean_episode_length{experiment=~\"$experiment\", run=~\"$run\"}",
          "legendFormat": "{{experiment}} / {{run}}",
          "editorMode": "code",
          "instant": true,
          "range": true,
          "format": "time_series"
        }
      ]
