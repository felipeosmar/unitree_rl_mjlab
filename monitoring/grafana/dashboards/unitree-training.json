{
  "annotations": {
    "list": []
  },
  "description": "M\u00e9tricas e logs do treinamento RL (rsl_rl) + viewer Viser embedado.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "uid": "unitree-rl-training",
  "title": "Unitree RL \u2014 Training Overview",
  "tags": [
    "unitree",
    "rl",
    "rsl_rl"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "experiment",
        "label": "Experiment",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(rsl_rl_step, experiment)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "sort": 1
      },
      {
        "name": "run",
        "label": "Run",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": {
          "qryType": 1,
          "query": "label_values(rsl_rl_step{experiment=~\"$experiment\"}, run)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "sort": 2
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Status do treinamento",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "type": "stat",
      "id": 1,
      "title": "Step atual",
      "description": "Itera\u00e7\u00e3o atual do PPO (rollout + \u00e9pocas de update). N\u00e3o \u00e9 env-step. Com 4096 envs, cada itera\u00e7\u00e3o \u2248 100k transi\u00e7\u00f5es.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (experiment, run) (rsl_rl_step{experiment=~\"$experiment\", run=~\"$run\"})",
          "legendFormat": "{{experiment}} / {{run}}",
          "editorMode": "code",
          "instant": true,
          "range": true,
          "format": "time_series"
        }
      ]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Mean reward (\u00faltimo)",
      "description": "Soma m\u00e9dia da reward por epis\u00f3dio na rollout atual (todos os termos somados). Term\u00f4metro do aprendizado \u2014 deve subir e estabilizar. Queda brusca = colapso.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0
              },
              {
                "color": "green",
                "value": 5
              }
            ]
          },
          "unit": "short",
          "decimals": 2
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "rsl_rl_train_mean_reward{experiment=~\"$experiment\", run=~\"$run\"}",
          "legendFormat": "{{experiment}} / {{run}}",
          "editorMode": "code",
          "instant": true,
          "range": true,
          "format": "time_series"
        }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Mean episode length",
      "description": "Dura\u00e7\u00e3o m\u00e9dia dos epis\u00f3dios em steps de simula\u00e7\u00e3o. Termina por timeout, fell_over ou illegal_contact. Rob\u00f4 est\u00e1vel = satura no max_episode_length.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short",
          "decimals": 0
